# ══════════════════════════════════════════════════════════════════════════
# SHARED — used by both bots + the Flask dashboard (single Postgres DB)
# ══════════════════════════════════════════════════════════════════════════
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trading_bot

# Flask dashboard
FLASK_SECRET_KEY=change-me-to-a-random-string

# ══════════════════════════════════════════════════════════════════════════
# SOL_TRADING_* — main bot (trader.py, scheduler.py, data_collector.py,
#                 claude_brain.py)
# ══════════════════════════════════════════════════════════════════════════
SOL_TRADING_DRY_RUN=true                # set to false only when ready for live trading

SOL_TRADING_SOLANA_PRIVATE_KEY=         # Base58 string or JSON array of 64 bytes
SOL_TRADING_SOLANA_RPC=https://api.mainnet-beta.solana.com

SOL_TRADING_CYCLE_MINUTES=20

SOL_TRADING_OPENROUTER_API_KEY=
SOL_TRADING_OPENROUTER_MODEL=anthropic/claude-sonnet-4-5
SOL_TRADING_OPENROUTER_MODEL_FAST=google/gemini-2.5-flash-lite

SOL_TRADING_COINGECKO_API_KEY=          # Optional — increases rate limits
SOL_TRADING_NEWSAPI_KEY=                # Optional — adds NewsAPI as a news source
SOL_TRADING_TWITTER_BEARER_TOKEN=       # Optional

SOL_TRADING_TELEGRAM_BOT_TOKEN=
SOL_TRADING_TELEGRAM_CHAT_ID=

SOL_TRADING_ENABLE_SENTIMENT=false

# Jupiter referral fee in basis points — the referral account itself is fixed
# in the source (supports the project), only the fee size is configurable here.
SOL_TRADING_JUPITER_REFERRAL_FEE_BPS=50

# ══════════════════════════════════════════════════════════════════════════
# SHITCOIN_HUNTER_* — separate, independent bot (shitcoin_hunter.py)
# Own wallet, own config. Experimental — see README Disclaimer.
# ══════════════════════════════════════════════════════════════════════════
SHITCOIN_HUNTER_DRY_RUN=true

SHITCOIN_HUNTER_SOLANA_PRIVATE_KEY=
SHITCOIN_HUNTER_SOLANA_PUBLIC_KEY=      # Display only, derived from the key above
SHITCOIN_HUNTER_SOLANA_RPC=https://api.mainnet-beta.solana.com

SHITCOIN_HUNTER_ENABLED=true
SHITCOIN_HUNTER_AMOUNT_USD=5            # USD per trade
SHITCOIN_HUNTER_MAX_POSITIONS=10        # max concurrent positions
SHITCOIN_HUNTER_TAKE_PROFIT=50          # % gain to auto-sell
SHITCOIN_HUNTER_STOP_LOSS=25            # % loss to auto-sell

SHITCOIN_HUNTER_OPENROUTER_API_KEY=     # Optional — separate key to track hunter costs independently; falls back to SOL_TRADING_OPENROUTER_API_KEY
SHITCOIN_HUNTER_OPENROUTER_MODEL_FAST=google/gemini-2.5-flash-lite
SHITCOIN_HUNTER_COINGECKO_API_KEY=      # Optional

SHITCOIN_HUNTER_TELEGRAM_BOT_TOKEN=
SHITCOIN_HUNTER_TELEGRAM_CHAT_ID=

SHITCOIN_HUNTER_JUPITER_REFERRAL_FEE_BPS=50
