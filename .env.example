# Solana wallet
SOLANA_PRIVATE_KEY=        # Base58 string or JSON array of 64 bytes
SOLANA_RPC=https://api.mainnet-beta.solana.com

# AI models (OpenRouter)
OPENROUTER_API_KEY=
OPENROUTER_MODEL_MAIN=anthropic/claude-sonnet-4-5
OPENROUTER_MODEL_FAST=google/gemini-2.5-flash-lite

# Market data
COINGECKO_API_KEY=         # Optional — increases rate limits
NEWSAPI_KEY=               # Optional — adds NewsAPI as news source

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Database
DATABASE_URL=sqlite:///trading_bot.db

# Safety — set to false only when ready for live trading
DRY_RUN=true

# Flask dashboard
FLASK_SECRET_KEY=change-me-to-a-random-string
